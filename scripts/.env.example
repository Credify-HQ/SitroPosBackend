# Environment variables for API Data Generator

# API Configuration
API_BASE_URL=http://localhost:8000/api

# Authentication
AUTH_EMAIL=admin@acmeretail.com
AUTH_PASSWORD=password

# Data Volume Presets
# Options: small, medium, large
DATA_PRESET=medium

# Custom volumes (override preset)
# CATEGORIES=15
# PRODUCTS=50
# CUSTOMERS=50
# SALES=1000
# DAYS_OF_SALES=60
