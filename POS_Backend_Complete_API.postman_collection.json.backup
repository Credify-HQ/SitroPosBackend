						"body": {
							"mode": "raw",
							"raw": "{\n    \"device_name\": \"POS Terminal 1\",\n    \"device_identifier\": \"POS-001-ABC123\",\n    \"branch_id\": {{branch_id}},\n    \"device_type\": \"pos_terminal\",\n    \"os_info\": \"Android 12\",\n    \"app_version\": \"1.0.0\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sync/register-device",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "register-device"]
						},
						"description": "Register a new device for offline sync.\n\n**Returns device_id** to use in subsequent sync requests.\n\n**Device Types:**\n- `pos_terminal` - POS hardware\n- `mobile` - Mobile app\n- `tablet` - Tablet app\n- `web` - Web browser"
					},
					"response": []
				},
				{
					"name": "Bootstrap Device",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							},
							{
								"key": "X-Device-Id",
								"value": "device-uuid-here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"branch_id\": {{branch_id}},\n    \"include_historical_data\": false,\n    \"days_of_history\": 30\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sync/bootstrap",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "bootstrap"]
						},
						"description": "Initial data download for new device.\n\n**Downloads:**\n- Products for branch\n- Categories\n- Payment methods\n- Customers\n- Current prices\n- Historical sales (optional)\n\n**Use once per device** after registration."
					},
					"response": []
				},
				{
					"name": "Pull Changes",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							},
							{
								"key": "X-Device-Id",
								"value": "device-uuid-here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"last_sync_timestamp\": \"2026-02-08T10:00:00Z\",\n    \"models\": [\"products\", \"customers\", \"categories\"]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sync/pull",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "pull"]
						},
						"description": "Download server changes since last sync.\n\n**Returns:**\n- Updated records\n- Deleted records\n- New records\n- Conflict markers\n\n**Call periodically** when online to stay synchronized."
					},
					"response": []
				},
				{
					"name": "Push Changes",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							},
							{
								"key": "X-Device-Id",
								"value": "device-uuid-here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"changes\": [\n        {\n            \"model\": \"sales\",\n            \"action\": \"create\",\n            \"client_uuid\": \"sale-offline-001\",\n            \"data\": {\n                \"branch_id\": {{branch_id}},\n                \"total_amount\": 299.99,\n                \"created_at\": \"2026-02-08T12:30:00Z\",\n                \"items\": [\n                    {\n                        \"product_id\": 1,\n                        \"quantity\": 2,\n                        \"price\": 149.99\n                    }\n                ],\n                \"payments\": [\n                    {\n                        \"payment_method_id\": 1,\n                        \"amount\": 299.99\n                    }\n                ]\n            }\n        },\n        {\n            \"model\": \"customers\",\n            \"action\": \"update\",\n            \"server_id\": 5,\n            \"client_uuid\": \"customer-update-001\",\n            \"data\": {\n                \"loyalty_points\": 150\n            }\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sync/push",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "push"]
						},
						"description": "Upload local changes to server.\n\n**Actions:**\n- `create` - New records\n- `update` - Modified records\n- `delete` - Deleted records\n\n**Idempotent:** Uses client_uuid to prevent duplicates.\n\n**Conflict Detection:** Returns conflicts for manual resolution."
					},
					"response": []
				},
				{
					"name": "Resolve Conflicts",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							},
							{
								"key": "X-Device-Id",
								"value": "device-uuid-here"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"resolutions\": [\n        {\n            \"conflict_id\": \"conflict-uuid-001\",\n            \"resolution\": \"server_wins\",\n            \"notes\": \"Accepting server version\"\n        },\n        {\n            \"conflict_id\": \"conflict-uuid-002\",\n            \"resolution\": \"client_wins\",\n            \"merged_data\": {\n                \"name\": \"Client Name\",\n                \"price\": 299.99\n            }\n        }\n    ]\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sync/resolve-conflicts",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "resolve-conflicts"]
						},
						"description": "Resolve sync conflicts.\n\n**Resolution Strategies:**\n- `server_wins` - Keep server version\n- `client_wins` - Keep client version (with merged_data)\n- `manual_merge` - Custom merged data\n\n**Call after receiving conflicts** from push or pull."
					},
					"response": []
				},
				{
					"name": "Get Sync Status",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							},
							{
								"key": "X-Device-Id",
								"value": "device-uuid-here"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/sync/status",
							"host": ["{{base_url}}"],
							"path": ["api", "sync", "status"]
						},
						"description": "Get current sync status for device.\n\n**Returns:**\n- Last sync timestamp\n- Pending changes count\n- Conflict count\n- Device info\n- Sync statistics"
					},
					"response": []
				}
			],
			"description": "Device registration and offline-first data synchronization with conflict resolution"
		}
	],
