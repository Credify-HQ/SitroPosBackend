						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"shift_id\", jsonData.shift.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
