		{
			"name": "Sales",
			"item": [
				{
					"name": "Create Sale",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"sale_id\", jsonData.sale.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"branch_id\": {{branch_id}},\n    \"shift_id\": 1,\n    \"customer_id\": null,\n    \"items\": [\n        {\n            \"product_id\": {{product_id}},\n            \"quantity\": 2,\n            \"price\": 299.99,\n            \"discount_amount\": 0\n        },\n        {\n            \"product_id\": 2,\n            \"quantity\": 1,\n            \"price\": 149.99,\n            \"discount_amount\": 10\n        }\n    ],\n    \"payments\": [\n        {\n            \"payment_method_id\": 1,\n            \"amount\": 739.97,\n            \"reference\": \"CASH-001\"\n        }\n    ],\n    \"discount_amount\": 10,\n    \"tax_amount\": 0,\n    \"notes\": \"Regular sale\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/sales",
							"host": ["{{base_url}}"],
							"path": ["api", "sales"]
						},
						"description": "Create a new sale with items and payments.\n\n**Features:**\n- Multiple items per sale\n- Multiple payment methods\n- Automatic inventory deduction (FEFO)\n- Links to active shift\n- Customer tracking (optional)\n\n**Auto-saves sale_id to collection variables**"
					},
					"response": []
				},
				{
					"name": "List Sales",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							},
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/sales?branch_id={{branch_id}}&status=completed&start_date=2026-02-01&end_date=2026-02-08",
							"host": ["{{base_url}}"],
							"path": ["api", "sales"],
							"query": [
								{
									"key": "branch_id",
									"value": "{{branch_id}}"
								},
								{
									"key": "status",
									"value": "completed",
