							"raw": "{\n    \"branch_id\": {{branch_id}},\n    \"product_id\": {{product_id}},\n    \"quantity\": 10,\n    \"reason\": \"expired\",\n    \"notes\": \"Products expired - batch #BT-2024-001\",\n    \"batch_id\": 1\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
