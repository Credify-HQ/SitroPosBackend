						},
						"description": "Get authenticated user details."
					},
					"response": []
				},
				{
					"name": "PIN Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"auth_token\", jsonData.token);",
									"    pm.collectionVariables.set(\"user_id\", jsonData.user.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"john@example.com\",\n    \"pin\": \"1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/pin-login",
							"host": ["{{base_url}}"],
							"path": ["api", "pin-login"]
						},
						"description": "Quick login using PIN instead of password.\n\n**No authentication required**\n\n**Requirements:**\n- User must have set a PIN first\n- PIN must be 4-6 digits\n\n**Auto-saves token to collection variables**"
					},
					"response": []
				},
				{
					"name": "Set PIN",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"pin\": \"1234\",\n    \"pin_confirmation\": \"1234\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/pin/set",
							"host": ["{{base_url}}"],
							"path": ["api", "pin", "set"]
						},
						"description": "Set or update user's PIN for quick login.\n\n**Requirements:**\n- PIN must be 4-6 digits\n- PIN and confirmation must match\n- User must be authenticated"
					},
					"response": []
				},
				{
					"name": "Remove PIN",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/pin/remove",
							"host": ["{{base_url}}"],
							"path": ["api", "pin", "remove"]
						},
						"description": "Remove user's PIN. User will need to use password login after this."
					},
					"response": []
				}
			],
			"description": "User authentication endpoints - register, login, logout, PIN management"
		},
