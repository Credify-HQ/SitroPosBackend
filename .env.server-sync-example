# .env.example additions for Server Sync

# ============================================
# Server-to-Server Sync Configuration
# ============================================

# Server Mode: cloud (master), edge (branch), or standalone (no sync)
SYNC_MODE=standalone

# Unique identifier for this server
LOCAL_SERVER_ID=server-001
LOCAL_SERVER_URL=http://localhost:8000/api

# Cloud Server Configuration (for edge servers)
CLOUD_SERVER_URL=https://pos-cloud.example.com/api
CLOUD_SERVER_TOKEN=

# Sync Behavior
AUTO_SYNC=true
SYNC_INTERVAL=30
SYNC_CONFLICT_RESOLUTION=latest_wins
SYNC_TIMEOUT=30
SYNC_MAX_RETRIES=3
