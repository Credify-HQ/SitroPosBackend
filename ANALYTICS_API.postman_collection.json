{
	"info": {
		"_postman_id": "analytics-api-collection-2026",
		"name": "POS Backend - Analytics API",
		"description": "Comprehensive analytics endpoints for revenue, profit, and business intelligence.\n\n## Authentication\nAll endpoints require:\n- **Bearer Token**: Sanctum authentication token\n- **X-Business-Id Header**: Current business context ID\n\n## Features\n- Organization-wide analytics with period comparisons\n- Branch-level performance tracking\n- Product sales analytics and rankings\n- Profit & Loss statements\n- Revenue growth trends over time\n- Automatic caching (15-30 minutes)\n\n## Permissions Required\n- `view analytics` - For most analytics endpoints\n- `view financial reports` - For profit/loss statements",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Organization Analytics",
			"item": [
				{
					"name": "Get Organization Analytics (Current Month)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Business-Id",
								"value": "{{business_id}}",
								"type": "text",
								"description": "Current business context ID"
							},
							{
								"key": "Accept",
								"value": "application/json",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/analytics/organization?period=month&compare_previous=true",
							"host": ["{{base_url}}"],
							"path": ["api", "analytics", "organization"],
							"query": [
								{
									"key": "period",
									"value": "month",
									"description": "Time period: today, week, month, year, custom"
								},
								{
									"key": "compare_previous",
									"value": "true",
									"description": "Include comparison with previous period"
								}
							]
						},
						"description": "Get organization-wide analytics for the current month with previous period comparison.\n\n**Returns:**\n- Current period metrics (revenue, profit, margin, transactions)\n- Previous period metrics\n- Comparison (% change, trends)\n- Branch contributions\n- Daily revenue trend"
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "GET",
								"header": [],
								"url": {
									"raw": "{{base_url}}/api/analytics/organization?period=month&compare_previous=true",
									"host": ["{{base_url}}"],
									"path": ["api", "analytics", "organization"]
								}
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"cookie": [],
							"body": "{\n    \"period\": {\n        \"start_date\": \"2026-02-01\",\n        \"end_date\": \"2026-02-08\",\n        \"days\": 8\n    },\n    \"current\": {\n        \"revenue\": \"125500.50\",\n        \"cost\": \"75300.30\",\n        \"profit\": \"50200.20\",\n        \"margin_percentage\": \"40.00\",\n        \"transaction_count\": 342,\n        \"average_order_value\": \"367.00\"\n    },\n    \"previous\": {\n        \"revenue\": \"98200.00\",\n        \"cost\": \"65100.00\",\n        \"profit\": \"33100.00\",\n        \"margin_percentage\": \"33.71\",\n        \"transaction_count\": 289,\n        \"average_order_value\": \"339.79\"\n    },\n    \"comparison\": {\n        \"revenue_change_percentage\": \"27.83\",\n        \"profit_change_percentage\": \"51.66\",\n        \"transaction_change_percentage\": \"18.34\",\n        \"revenue_trend\": \"up\",\n        \"profit_trend\": \"up\"\n    },\n    \"branch_contributions\": [\n        {\n            \"branch_id\": 1,\n            \"branch_name\": \"Main Branch\",\n            \"revenue\": \"75300.30\",\n            \"profit\": \"30120.12\",\n            \"transaction_count\": 205,\n            \"contribution_percentage\": \"60.00\"\n        },\n        {\n            \"branch_id\": 2,\n            \"branch_name\": \"Downtown Branch\",\n            \"revenue\": \"50200.20\",\n            \"profit\": \"20080.08\",\n            \"transaction_count\": 137,\n            \"contribution_percentage\": \"40.00\"\n        }\n    ],\n    \"revenue_trend\": [\n        {\n            \"date\": \"2026-02-01\",\n            \"revenue\": \"15687.50\",\n            \"transactions\": 42\n        },\n        {\n            \"date\": \"2026-02-02\",\n            \"revenue\": \"18234.75\",\n            \"transactions\": 51\n        }\n    ]\n}"
						}
					]
				},
